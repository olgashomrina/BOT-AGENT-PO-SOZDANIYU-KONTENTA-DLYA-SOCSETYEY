# Скопируйте этот файл в файл с именем .env и заполните реальными значениями.
# Файл .env НЕ должен попадать в Git — он уже добавлен в .gitignore.
# Если вы не программист: просто создайте рядом файл ".env" (без .example
# в конце) и заполните значения после знака "=" — без пробелов и без кавычек.

# Токен Telegram-бота. Получить его можно у @BotFather в Telegram:
# напишите ему /newbot и следуйте инструкциям.
BOT_TOKEN=

# Ключ доступа к российскому ИИ-прокси (например, vsegpt.ru), через который
# бот обращается к ИИ-моделям для генерации текста и расшифровки голоса.
AI_PROXY_API_KEY=

# Telegram chat id владельца бота — сюда бот будет присылать уведомления
# об ошибках и падениях. Узнать свой chat id можно, написав боту @userinfobot.
OWNER_CHAT_ID=

# Сколько запросов на генерацию контента разрешено одному пользователю в день.
# Необязательно, по умолчанию 20.
DAILY_LIMIT=20

# Сколько запросов на генерацию контента разрешено одному пользователю в месяц.
# Необязательно, по умолчанию 300.
MONTHLY_LIMIT=300

# Путь к файлу базы данных SQLite (создастся автоматически при первом запуске).
# Необязательно, по умолчанию bot.db.
DB_PATH=bot.db

# Уровень логирования: DEBUG, INFO, WARNING, ERROR.
# Для обычной работы достаточно INFO. Необязательно, по умолчанию INFO.
LOG_LEVEL=INFO

# Адрес ИИ-прокси (OpenAI-совместимый API, например vsegpt.ru).
# Необязательно, по умолчанию https://api.vsegpt.ru/v1.
AI_PROXY_BASE_URL=https://api.vsegpt.ru/v1

# Название провайдера — используется только в логах для диагностики.
# Необязательно, по умолчанию vsegpt.
AI_GATEWAY_PROVIDER=vsegpt

# Модель для генерации текста. Необязательно, по умолчанию openai/gpt-4o-mini.
AI_GATEWAY_TEXT_MODEL=openai/gpt-4o-mini

# Модель для расшифровки голосовых сообщений. Необязательно, по умолчанию stt-openai/whisper-1.
AI_GATEWAY_TRANSCRIPTION_MODEL=stt-openai/whisper-1

# Сколько раз повторять запрос к ИИ-прокси при таймауте/сбое сервера.
# Необязательно, по умолчанию 2.
AI_GATEWAY_MAX_RETRIES=2

# Сколько секунд ждать ответа от ИИ-прокси, прежде чем считать это таймаутом.
# Необязательно, по умолчанию 30.
AI_GATEWAY_TIMEOUT_SECONDS=30

# Сколько вариантов текста генерировать на каждую площадку (Telegram, VK).
# Необязательно, по умолчанию 2.
CONTENT_VARIANTS_COUNT=2
